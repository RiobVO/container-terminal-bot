BOT_TOKEN=
ADMIN_IDS=123456789,987654321
DATABASE_PATH=./container.db

# Тариф по умолчанию (можно переопределить для каждой компании в UI)
DEFAULT_ENTRY_FEE=20
DEFAULT_FREE_DAYS=30
DEFAULT_STORAGE_RATE=20
DEFAULT_STORAGE_PERIOD_DAYS=30

# Telegram-группы, куда бот шлёт утренний/вечерний отчёт (через запятую)
GROUP_IDS=

# Время рассылки отчётов (0-23, по TIMEZONE)
REPORT_HOUR=6
EVENING_REPORT_HOUR=20
TIMEZONE=Asia/Tashkent

# FSM-хранилище. Пусто = MemoryStorage (для локалки ок).
# Для docker-compose: REDIS_URL=redis://redis:6379/0
REDIS_URL=

# Канал для автобэкапов БД (бот должен быть админом канала)
BACKUP_CHAT_ID=
